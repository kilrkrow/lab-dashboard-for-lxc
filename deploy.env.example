# Copy to deploy.env (gitignored) for agent/live iteration.
# Agents load this automatically when present.

# SSH + rsync target (static webroot)
LXC_USER=root
LXC_HOST=192.168.86.4
LXC_PATH=/var/www/html
LXC_SSH_KEY=C:\Users\you\path\to\private_key_openssh

# Public or LAN URL for smoke tests (browser-facing site)
HAVEN_URL=http://192.168.86.4
# HAVEN_URL=https://home.lan.monkiesaresm.art

# Optional: ship broker source + restart (integrations: DR7, GitHub, …)
# BROKER_REMOTE_DIR=/opt/haven-lab
# BROKER_RESTART_CMD=systemctl restart haven-broker
# If broker is reached on a different base than HAVEN_URL:
# BROKER_URL=http://192.168.86.4:3000
