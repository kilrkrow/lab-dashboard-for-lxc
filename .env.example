# GitHub Personal Access Token (fine-grained, minimal scopes recommended)
# Used for /api/repos proxy during local development
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) If you want to proxy config.json during dev instead of using a local file
# VITE_CONFIG_PROXY_TARGET=https://raw.githubusercontent.com
# VITE_CONFIG_PROXY_PATH=/YOUR_USERNAME/YOUR_PRIVATE_REPO/main/config.json