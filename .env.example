# Haven Lab broker — copy to .env and fill in your values

# GitHub
GITHUB_USER=kilrkrow
GITHUB_TOKEN=

# UniFi (host only, e.g. 192.168.1.1 or https://192.168.1.1)
UNIFI_HOST=
UNIFI_USER=
UNIFI_PASS=
UNIFI_SITE=default

# Proxmox
PROXMOX_HOST=
PROXMOX_TOKENID=
PROXMOX_SECRET=
PROXMOX_NODE=pve

# AdGuard Home
ADGUARD_HOST=
ADGUARD_USER=admin
ADGUARD_PASS=

# Broker
CONFIG_PATH=/etc/haven/config.json
PORT=3000
