# Haven Lab broker — copy to .env and fill in your values

# GitHub — two-token model recommended
# RO: list repos / issues / PRs (can be Portainer RO classic, or fine-grained read)
GITHUB_USER=kilrkrow
GITHUB_TOKEN=
# GITHUB_RO_TOKEN=          # optional alias for GITHUB_TOKEN
# RW: Save-to-GitHub only (fine-grained Contents:Write on the config repo, e.g. homelab-stacks)
# GITHUB_WRITE_TOKEN=

# UniFi (same shape as UniFiHUD — API key preferred)
# Host only (192.168.1.1) or full URL (https://192.168.1.1)
UNIFI_HOST=
UNIFI_API_KEY=
UNIFI_USER=
UNIFI_PASS=
UNIFI_SITE=
# Optional: force API prefix. Blank = auto-try /proxy/network then classic.
# UNIFI_API_PREFIX=/proxy/network

# Proxmox
PROXMOX_HOST=
PROXMOX_TOKENID=
PROXMOX_SECRET=
PROXMOX_NODE=pve

# AdGuard Home
ADGUARD_HOST=
ADGUARD_USER=admin
ADGUARD_PASS=

# Broker
CONFIG_PATH=/etc/haven/config.json
PORT=3000
