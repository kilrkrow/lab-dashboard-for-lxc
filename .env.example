# Haven Lab broker — copy to .env and fill in your values
# UniFi (API key preferred; falls back to user/pass session)
UNIFI_URL=
UNIFI_API_KEY=
UNIFI_USER=readonly
UNIFI_PASS=

# GitHub
GITHUB_TOKEN=github_pat_...
GITHUB_USER=kilrkrow

# Proxmox (PVEAPIToken=user@pam!tokenid=secret)
PROXMOX_URL=
PROXMOX_TOKEN=
PROXMOX_NODE=pve

# AdGuard Home
ADGUARD_URL=
ADGUARD_USER=admin
ADGUARD_PASS=

# Broker
CONFIG_PATH=/etc/haven/config.json
PORT=3000
